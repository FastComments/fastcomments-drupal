<?php

/**
 * @file
 * Hook implementations for the FastComments module.
 */

/**
 * Implements hook_theme().
 */
function fastcomments_theme() {
  return [
    'fastcomments_widget' => [
      'variables' => [
        'config_json' => '',
        'commenting_style' => 'comments',
        'cdn_url' => 'https://cdn.fastcomments.com',
        'url_id' => '',
        'noscript_url' => '',
        'show_noscript' => TRUE,
      ],
      'template' => 'fastcomments-widget',
    ],
  ];
}
